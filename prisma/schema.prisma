generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(uuid())
  name                String
  email               String   @unique
  avatarUrl           String?  @map("avatar_url")
  hardcoverUserId     String?  @map("hardcover_user_id")
  hardcoverUsername    String?  @map("hardcover_username")
  hardcoverApiToken   String?  @map("hardcover_api_token")
  supabaseAuthId      String   @unique @map("supabase_auth_id")
  createdAt           DateTime @default(now()) @map("created_at")

  householdMembers    HouseholdMember[]
  recommendationsSent Recommendation[]  @relation("RecommendationFrom")
  recommendationsReceived Recommendation[] @relation("RecommendationTo")
  plusOnes            PlusOne[]
  snapshots           Snapshot[]
  activityEvents      ActivityEvent[]   @relation("ActivityEvents")
  activityTargets     ActivityEvent[]   @relation("ActivityTargets")
  userBookMediaTypes  UserBookMediaType[]
  bookRankings        BookRanking[]
  bookComparisons     BookComparison[]
  articles            Article[]
  articleRecsSent      ArticleRecommendation[] @relation("ArticleRecFrom")
  articleRecsReceived  ArticleRecommendation[] @relation("ArticleRecTo")
  articleSaves        ArticleSave[]

  @@map("users")
}

model Household {
  id        String   @id @default(uuid())
  name      String
  inviteCode String  @unique @map("invite_code")
  createdAt DateTime @default(now()) @map("created_at")

  members   HouseholdMember[]

  @@map("households")
}

model HouseholdMember {
  id          String   @id @default(uuid())
  householdId String   @map("household_id")
  userId      String   @map("user_id")
  role        String   @default("member")

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

model Recommendation {
  id              String   @id @default(uuid())
  fromUserId      String   @map("from_user_id")
  toUserId        String   @map("to_user_id")
  hardcoverBookId String   @map("hardcover_book_id")
  bookTitle       String?  @map("book_title")
  bookAuthor      String?  @map("book_author")
  bookCoverUrl    String?  @map("book_cover_url")
  note            String?
  status          String   @default("pending")
  createdAt       DateTime @default(now()) @map("created_at")

  fromUser        User     @relation("RecommendationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User     @relation("RecommendationTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

model PlusOne {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  hardcoverBookId String   @map("hardcover_book_id")
  bookTitle       String?  @map("book_title")
  bookAuthor      String?  @map("book_author")
  bookCoverUrl    String?  @map("book_cover_url")
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hardcoverBookId])
  @@map("plus_ones")
}

model ActivityEvent {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  type            String   // status_change | rating | progress_update | recommendation | plus_one | article_shared | article_recommended
  hardcoverBookId String?  @map("hardcover_book_id")
  bookTitle       String?  @map("book_title")
  bookAuthor      String?  @map("book_author")
  bookCoverUrl    String?  @map("book_cover_url")
  value           String?  // e.g. "Currently Reading", "4.5", "45%", "page 120"
  targetUserId    String?  @map("target_user_id")
  note            String?
  mediaType       String?  @map("media_type") // "book" | "ebook" | "audiobook"
  visibility      String   @default("global") // "global" | "private"
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation("ActivityEvents", fields: [userId], references: [id], onDelete: Cascade)
  targetUser      User?    @relation("ActivityTargets", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@map("activity_events")
}

model UserBookMediaType {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  hardcoverBookId String   @map("hardcover_book_id")
  mediaType       String   @default("book") @map("media_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hardcoverBookId])
  @@map("user_book_media_types")
}

model Snapshot {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  type            String   @default("user_book")
  hardcoverBookId String   @map("hardcover_book_id")
  statusId        Int?     @map("status_id")
  rating          Float?
  progressPct     Float?   @map("progress_pct")
  bookTitle       String?  @map("book_title")
  bookAuthor      String?  @map("book_author")
  bookCoverUrl    String?  @map("book_cover_url")
  updatedAt       DateTime @default(now()) @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hardcoverBookId])
  @@map("snapshots")
}

model BookRanking {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  hardcoverBookId String   @map("hardcover_book_id")
  eloScore        Float    @default(1500) @map("elo_score")
  manualOverride  Float?   @map("manual_override")
  comparisonCount Int      @default(0) @map("comparison_count")
  bookTitle       String?  @map("book_title")
  bookAuthor      String?  @map("book_author")
  bookCoverUrl    String?  @map("book_cover_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hardcoverBookId])
  @@map("book_rankings")
}

model BookComparison {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  winnerBookId    String   @map("winner_book_id")
  loserBookId     String   @map("loser_book_id")
  isDraw          Boolean  @default(false) @map("is_draw")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("book_comparisons")
}

model Article {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  url         String?
  title       String
  description String?
  source      String?  // domain name (e.g. "nytimes.com") or manual label
  imageUrl    String?  @map("image_url")
  tags        String   @default("[]") // JSON array of tag strings
  note        String?  // personal note from the sharer
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user                   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleRecommendations ArticleRecommendation[]
  articleSaves           ArticleSave[]

  @@map("articles")
}

model ArticleRecommendation {
  id         String   @id @default(uuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  articleId  String   @map("article_id")
  note       String?
  status     String   @default("pending") // pending | seen | saved | dismissed
  createdAt  DateTime @default(now()) @map("created_at")

  fromUser User    @relation("ArticleRecFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("ArticleRecTo", fields: [toUserId], references: [id], onDelete: Cascade)
  article  Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_recommendations")
}

model ArticleSave {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  articleId String   @map("article_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@map("article_saves")
}
